   "id": "b4da630a-6a94-4401-ac08-5dc628b50999",
   "metadata": {},
   "source": [
    "import socket\n",
    "import subprocess\n",
    "import platform\n",
    "\n",
    "def ping_host(host):\n",
    "    print(f\"\\nPinging {host}...\")\n",
    "    try:\n",
    "        param = \"-n\" if platform.system().lower() == \"windows\" else \"-c\"\n",
    "        output = subprocess.run([\"ping\", param, \"4\", host], capture_output=True, text=True)\n",
    "        print(output.stdout)\n",
    "    except Exception as e:\n",
    "        print(\"Ping failed:\", e)\n",
    "\n",
    "def dns_lookup(domain):\n",
    "    print(f\"\\nLooking up DNS for {domain}...\")\n",
    "    try:\n",
    "        ip = socket.gethostbyname(domain)\n",
    "        print(f\"IP Address: {ip}\")\n",
    "    except socket.gaierror:\n",
    "        print(\"DNS lookup failed.\")\n",
    "\n",
    "def scan_port(host, port):\n",
    "    print(f\"\\nChecking port {port} on {host}...\")\n",
    "    try:\n",
    "        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n",
    "        s.settimeout(2)\n",
    "        result = s.connect_ex((host, port))\n",
    "        if result == 0:\n",
    "            print(f\"Port {port} is OPEN\")\n",
    "        else:\n",
    "            print(f\"Port {port} is CLOSED\")\n",
    "        s.close()\n",
    "    except Exception as e:\n",
    "        print(\"Port scan failed:\", e)\n",
    "\n",
    "def get_local_ip():\n",
    "    hostname = socket.gethostname()\n",
    "    local_ip = socket.gethostbyname(hostname)\n",
    "    print(f\"\\nLocal IP Address: {local_ip}\")\n",
    "\n",
    "def traceroute(host):\n",
    "    print(f\"\\nRunning traceroute for {host}...\\n\")\n",
    "    try:\n",
    "        system = platform.system().lower()\n",
    "\n",
    "        if system == \"windows\":\n",
    "            cmd = [\"tracert\", host]\n",
    "        else:\n",
    "            cmd = [\"traceroute\", host]\n",
    "\n",
    "        output = subprocess.run(cmd, capture_output=True, text=True)\n",
    "        print(output.stdout)\n",
    "\n",
    "    except Exception as e:\n",
    "        print(\"Traceroute failed:\", e)\n",
    "\n",
    "def main():\n",
    "    while True:\n",
    "        print(\"\\n--- Network Troubleshooter ---\")\n",
    "        print(\"1. Ping Host\")\n",
    "        print(\"2. DNS Lookup\")\n",
    "        print(\"3. Scan Port\")\n",
    "        print(\"4. Get Local IP\")\n",
    "        print(\"5. Traceroute\")\n",
    "        print(\"6. Exit\")\n",
    "\n",
    "        choice = input(\"Enter choice: \")\n",
    "\n",
    "        if choice == \"1\":\n",
    "            host = input(\"Enter host/IP: \")\n",
    "            ping_host(host)\n",
    "\n",
    "        elif choice == \"2\":\n",
    "            domain = input(\"Enter domain: \")\n",
    "            dns_lookup(domain)\n",
    "\n",
    "        elif choice == \"3\":\n",
    "            host = input(\"Enter host/IP: \")\n",
    "            port = int(input(\"Enter port: \"))\n",
    "            scan_port(host, port)\n",
    "\n",
    "        elif choice == \"4\":\n",
    "            get_local_ip()\n",
    "\n",
    "        elif choice == \"5\":\n",
    "            host = input(\"Enter host/IP: \")\n",
    "            traceroute(host)\n",
    "\n",
    "        elif choice == \"6\":\n",
    "            print(\"Exiting...\")\n",
    "            break\n",
    "\n",
    "        else:\n",
    "            print(\"Invalid choice.\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()"
   ]
  },
